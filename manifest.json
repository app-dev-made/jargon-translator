  "id": "/",
  "name": "Jargon Lens - Plain English Translator",
  "short_name": "Jargon Lens",
  "description": "Instantly translate legal, business, and financial jargon into plain English. Upload a document or paste text to get a simple, friendly breakdown of what it really means.",
  "start_url": "index.html",
  "scope": "./",
  "display": "standalone",
