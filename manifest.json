{
  "name": "EasyEnglish – Plain English Translator",
  "short_name": "EasyEnglish",
  "start_url": "index.html",
  "display": "standalone",
  "background_color": "#1a1a2e",
  "theme_color": "#6c63ff",
  "orientation": "portrait-primary",
  "icons": [
    { "src": "icons/icon-192x192.png", "type": "image/png", "sizes": "192x192" },
    { "src": "icons/icon-512x512.png", "type": "image/png", "sizes": "512x512", "purpose": "any maskable" }
  ],
  "file_handlers": [
    {
      "action": "index.html",
      "accept": {
        "image/*": [".jpg", ".jpeg", ".png"],
        "application/pdf": [".pdf"]
      }
    }
  ],
  "share_target": {
    "action": "index.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
}
