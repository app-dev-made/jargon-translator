{
  "id": "com.easyenglish.app.v1",
  "version": "1.0.0",
  "name": "EasyEnglish",
  "short_name": "EasyEnglish",
  "lang": "en-US",
  "dir": "ltr",
  "description": "Instantly translate confusing legal and business jargon into Easy English. Spot red flags in contracts and understand your rights.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "tabbed", "standalone"],
  "background_color": "#1a1a2e",
  "theme_color": "#6c63ff",
  "orientation": "portrait",
  "categories": ["productivity", "utilities", "education"],
  "iarc_rating_id": "e58c1f10-1234-5678-90ab-cdef12345678",
  "icons": [
    {
      "src": "icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "EasyEnglish Mobile View"
    },
    {
      "src": "icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "wide",
      "label": "EasyEnglish Desktop View"
    }
  ],
  "shortcuts": [
    {
      "name": "Start Translating",
      "short_name": "Translate",
      "description": "Open EasyEnglish immediately",
      "url": "./index.html",
      "icons": [{ "src": "icons/icon-192x192.png", "sizes": "192x192" }]
    }
  ],
  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },
  "share_target": {
    "action": "./index.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "note_taking": {
    "new_note_url": "./index.html"
  },
  "protocol_handlers": [
    {
      "protocol": "web+easyenglish",
      "url": "./index.html?query=%s"
    }
  ],
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.easyenglish.app",
      "id": "com.easyenglish.app"
    }
  ],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  }
}
