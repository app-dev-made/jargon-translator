      "label": "Get a plain English breakdown with red flags highlighted"
    }
  ],
  "shortcuts": [
    {
      "name": "Scan Document",
      "short_name": "Scan",
      "description": "Open camera to scan a document",
      "url": "index.html?action=scan",
      "icons": [
        {
          "src": "icons/icon-96x96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Paste Text",
      "short_name": "Paste",
      "description": "Paste text to translate jargon",
      "url": "index.html?action=paste",
      "icons": [
        {
          "src": "icons/icon-96x96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "My History",
      "short_name": "History",
      "description": "View past translations",
      "url": "index.html?action=history",
      "icons": [
        {
          "src": "icons/icon-96x96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "share_target": {
    "action": "index.html",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "document",
          "accept": [
            "image/*",
            "application/pdf",
            "text/*"
          ]
        }
      ]
    }
  },
  "launch_handler": {
    "client_mode": [
      "navigate-existing",
      "auto"
    ]
  },
  "protocol_handlers": [
    {
      "protocol": "web+jargonlens",
      "url": "index.html?text=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "index.html",
      "accept": {
        "image/*": [
          ".jpg",
          ".jpeg",
          ".png",
          ".gif",
          ".webp"
        ],
        "text/plain": [
          ".txt"
        ],
        "application/pdf": [
          ".pdf"
        ]
      }
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "handle_links": "preferred",
  "scope_extensions": []
}