      "url": "/jargon-translator/index.html?action=scan",
      "icons": [{ "src": "icons/icon-192x192.png", "sizes": "192x192" }]
    },
    {
      "name": "Paste Text",
      "short_name": "Paste",
      "description": "Instantly paste text for analysis",
      "url": "/jargon-translator/index.html?action=paste",
      "icons": [{ "src": "icons/icon-192x192.png", "sizes": "192x192" }]
